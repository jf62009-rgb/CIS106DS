def calcforecast(sales,month): #passing to the function month and sales
    if month in (1,2,3):
        forecastpercent = 0.1  # I figured it would be more convenient to have each month correspond with a number as it would be easier to input an integer value
    elif month in (4, 5, 6):
        forecastpercent = 0.15
    elif month in (7, 8, 9):
        forecastpercent = 0.2
    else:
        forecastpercent = 0.25     #as we could input different months I had to incorporate if elif and else to ensure that all months could be accounted for.
    next_months_sales= (sales * (1+forecastpercent))
    return next_months_sales
  

keep_going = input("start calculation? y/n")
while keep_going == "y": #beginning while loop
    last_name = input("Enter last name") #inputting the variables
    sales = float(input("Enter sales amount: $"))
    month = int(input("Enter month number (January= 1, December = 12): "))

    next_months_sales= calcforecast(sales,month) #running the function
   
   
    
    print("Next month's sales: $",next_months_sales,)
    print("employees last name",last_name)
    
    keep_going = input("keep going? y/n")        

