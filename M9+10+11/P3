def calcforecast(sales,month):
    if month in (1,2,3):
        forecastpercent = 0.1
    elif month in (4, 5, 6):
        forecastpercent = 0.15
    elif month in (7, 8, 9):
        forecastpercent = 0.2
    else:
        forecastpercent = 0.25
    next_months_sales= (sales * (1+forecastpercent))
    return next_months_sales
  

