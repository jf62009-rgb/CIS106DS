#setting up the function, naming the function calcTotal
def calcTotal(price, quantity):
    Total = (price * quantity)
   #adding the discount 
    if Total > 10000:
        Total = Total *.90 
        
    return Total    #return so I actually get a value back when I run the function

#declare the total extended price
TEP = 0



